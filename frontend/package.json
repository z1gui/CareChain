    "lint:fix": "eslint --fix",
    "shadcn": "shadcn"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@solana/client": "^1.7.0",
    "@solana/kit": "^6.8.0",
    "@solana/react-hooks": "^1.4.1",
    "@tanstack/react-query": "^5.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "server-only": "^0.0.1",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@codama/nodes-from-anchor": "^1.4.1",
    "@codama/renderers-js": "^1.5.5",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@next/eslint-plugin-next": "^16.2.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": ">=22.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "codama": "^1.6.0",
    "eslint": "^10.2.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "tailwindcss": "^4",
    "typescript": "^5.1.6"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [],
      "allowedVersions": {
        "typescript": "*",
        "zod": "*"
      }
    }
