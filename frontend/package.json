{
  "name": "care-chain-frontend",
  "packageManager": "pnpm@8.15.6",
  "description": "This is the frontend project for the Care Chain.",
  "license": "MIT",
  "homepage": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/z1gui/CareChain/tree/main/frontend"
  },
  "keywords": [
    "colosseum",
    "care-chain",
    "frontend",
    "rwa"
  ],
  "engines": {
